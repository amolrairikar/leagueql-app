{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": [
        "s3:GetReplicationConfiguration",
        "s3:ListBucket"
      ],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:s3:::fantasy-football-recap-dev-bucket-${region1}-${account_id}",
        "arn:aws:s3:::fantasy-football-recap-dev-bucket-${region2}-${account_id}"
      ]
    },
    {
      "Action": [
        "s3:GetObjectVersionForReplication",
        "s3:GetObjectVersionAcl",
        "s3:GetObjectVersionTagging",
        "s3:ReplicateObject",
        "s3:ReplicateDelete",
        "s3:ReplicateTags"
      ],
      "Effect": "Allow",
      "Resource": [
        "arn:aws:s3:::fantasy-football-recap-dev-bucket-${region1}-${account_id}/*",
        "arn:aws:s3:::fantasy-football-recap-dev-bucket-${region2}-${account_id}/*"
      ]
    }
  ]
}